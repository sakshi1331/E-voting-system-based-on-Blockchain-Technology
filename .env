# Server Config
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://localhost:27017/evoting-system
DB_NAME=evoting-system

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Email Configuration (Gmail/Custom)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_college_email@gmail.com
SMTP_PASSWORD=your_app_password
MAIL_FROM=noreply@college-evoting.edu
MAIL_FROM_NAME=College E-Voting System

# College Configuration
COLLEGE_EMAIL_DOMAIN=@college.edu
COLLEGE_NAME=Your College Name
OTP_EXPIRY=5 # minutes

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://localhost:7545
SMART_CONTRACT_ADDRESS=0x_your_deployed_contract_address
SMART_CONTRACT_ABI_PATH=./build/contracts/Election.json

# Security
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15 # minutes
API_RATE_LIMIT=100 # requests per 15 minutes

# Session
SESSION_SECRET=your_session_secret_key
